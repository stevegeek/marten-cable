#!/usr/bin/env bash
# Wrapper around `crystal` that exports CRYSTAL_LIBRARY_PATH.
# asdf 0.18 (Go-based) bypasses the upstream asdf-crystal bash wrapper that
# normally exports it, so `ld: library 'gc' not found` without this.
set -euo pipefail
export CRYSTAL_LIBRARY_PATH="${CRYSTAL_LIBRARY_PATH:+$CRYSTAL_LIBRARY_PATH:}$HOME/.asdf/installs/crystal/1.20.1/embedded/lib"
exec crystal "$@"
